# =============================================================================
# Community Health Inspector Analytics Dashboard — Environment Variables
# Copy to .env for local development. Set these in Railway → Variables.
# NEVER commit .env to git.
# =============================================================================

# --- Database (Supabase PostgreSQL) ---
# Use Supabase Session/Transaction pooler URL (IPv4-friendly), port 6543:
# postgresql://postgres.PROJECT_REF:PASSWORD@aws-REGION.pooler.supabase.com:6543/postgres
DATABASE_URL=

# Schema and table for health indicator data (read-only)
HEALTH_DB_SCHEMA=public
HEALTH_DB_TABLE=health_summary

# Force SSL for remote PostgreSQL (default: true)
DATABASE_SSL=true
DB_CONN_MAX_AGE=600

# --- Django core ---
# Generate: python -c "import secrets; print(secrets.token_urlsafe(50))"
DJANGO_SECRET_KEY=

# false in production (Railway)
DJANGO_DEBUG=false

# Comma-separated hosts. Railway auto-adds RAILWAY_PUBLIC_DOMAIN and .up.railway.app
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1,.railway.app

# Comma-separated origins. Railway auto-adds https://YOUR_APP.up.railway.app
CSRF_TRUSTED_ORIGINS=

# Time zone for dashboard dates
DJANGO_TIME_ZONE=Asia/Karachi

# Secure cookies (auto true on Railway when DEBUG=false)
SESSION_COOKIE_SECURE=true
CSRF_COOKIE_SECURE=true

# Optional HTTPS redirect (usually handled by Railway edge)
SECURE_SSL_REDIRECT=false
SECURE_HSTS_SECONDS=0

# --- Application ---
DASHBOARD_CACHE_TTL=300

# --- Dashboard user passwords (used by setup_dashboard_users on deploy) ---
SUPERADMIN_USERNAME=superadmin
SUPERADMIN_PASSWORD=
DASHBOARD_VIEWER_USERNAME=H&PD
DASHBOARD_VIEWER_PASSWORD=

# --- Gunicorn (optional) ---
WEB_CONCURRENCY=2
GUNICORN_TIMEOUT=120
GUNICORN_LOG_LEVEL=info

# --- Logging ---
LOG_LEVEL=INFO
DJANGO_LOG_LEVEL=INFO

# --- Railway-provided (do not set manually) ---
# PORT
# RAILWAY_PUBLIC_DOMAIN
# RAILWAY_STATIC_URL
# RAILWAY_ENVIRONMENT
